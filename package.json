{
  "name": "@absolutejs/rag",
  "version": "0.0.22",
  "description": "Standalone RAG ingestion, sync, retrieval, evaluation, clients, and framework adapters extracted from AbsoluteJS",
  "license": "BSL-1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./adapter-kit": {
      "import": "./dist/adapter-kit/index.js",
      "types": "./dist/src/adapter-kit/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/src/client/index.d.ts"
    },
    "./client/ui": {
      "import": "./dist/client/ui.js",
      "types": "./dist/src/client/ui.d.ts"
    },
    "./ui": {
      "import": "./dist/presentation/ui.js",
      "types": "./dist/src/presentation/ui.d.ts"
    },
    "./quality": {
      "import": "./dist/quality/quality.js",
      "types": "./dist/src/quality/quality.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/src/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/src/vue/index.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte/index.js",
      "types": "./dist/src/svelte/index.d.ts"
    },
    "./angular": {
      "import": "./dist/angular/index.js",
      "types": "./dist/src/angular/index.d.ts"
    }
  },
  "dependencies": {
    "@absolutejs/ai": "^0.0.9",
    "@absolutejs/linked-providers": "0.0.2",
    "@absolutejs/sync": "^1.8.1"
  },
  "peerDependencies": {
    "@angular/core": "^21.0.0",
    "elysia": "^1.4.18",
    "react": "^19.2.0",
    "svelte": "^5.35.2",
    "vue": "^3.5.27"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@absolutejs/absolute": "^0.19.0-beta.1051",
    "@angular/core": "^21.0.0",
    "@types/bun": "1.3.9",
    "@types/react": "19.2.0",
    "elysia": "1.4.18",
    "react": "19.2.1",
    "svelte": "5.55.0",
    "typescript": "^5.9.3",
    "vue": "3.5.27",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.56.1",
    "eslint-plugin-absolute": "^0.2.6",
    "eslint-plugin-promise": "^7.2.1",
    "react-dom": "19.2.1"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "config": "absolute config",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "bun test",
    "release": "bun publish --access public"
  },
  "publishConfig": {
    "access": "public"
  },
  "typesVersions": {
    "*": {
      "adapter-kit": [
        "dist/src/adapter-kit/index.d.ts"
      ],
      "client": [
        "dist/src/client/index.d.ts"
      ],
      "client/ui": [
        "dist/src/client/ui.d.ts"
      ],
      "ui": [
        "dist/src/presentation/ui.d.ts"
      ],
      "quality": [
        "dist/src/quality/quality.d.ts"
      ],
      "react": [
        "dist/src/react/index.d.ts"
      ],
      "vue": [
        "dist/src/vue/index.d.ts"
      ],
      "svelte": [
        "dist/src/svelte/index.d.ts"
      ],
      "angular": [
        "dist/src/angular/index.d.ts"
      ]
    }
  }
}
